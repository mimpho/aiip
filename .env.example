# .env.example — Variables de entorno del proyecto AIIP
# Copia este fichero a .env y rellena los valores reales.
# NUNCA commitees el fichero .env — está en .gitignore.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Google AI (Gemini) ────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.1
LLM_MAX_TOKENS=1024

# ── Hugging Face ──────────────────────────────────────────────
HF_TOKEN=your-huggingface-read-token
EMBEDDINGS_MODEL=BAAI/bge-m3

# ── Google Drive (Colab) ──────────────────────────────────────
DRIVE_BASE_PATH=/content/drive/MyDrive/TFM Master IA/AIIP

# ── Pipeline RAG ─────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
RAG_TOP_K=5

# ── Ingesta de la KB (E-06) ───────────────────────────────────────────────────
KB_RAW_DATA_PATH=data/raw
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ── Puertos de los entrypoints Chainlit (D-010: nunca hardcodeados) ──────────
PORT_FAMILY=8000
PORT_PROFESSIONAL=8001

# ── Chainlit ──────────────────────────────────────────────────
# Firma las sesiones (JWT, HS256) — genera uno con `chainlit create-secret`.
# Cambiar el valor desconecta a todos los usuarios con sesión activa.
CHAINLIT_AUTH_SECRET=your-chainlit-auth-secret

# ── Login con Google (D-032/D-040) ─────────────────────────────
# Nombres fijos de Chainlit (chainlit/oauth_providers.py), no elegibles.
# Reutilizan el proyecto de Google Cloud de Supabase (D-014), con un
# redirect URI nuevo — paso manual en Google Cloud Console. Si no están
# configuradas, @cl.oauth_callback no se registra y el botón de Google
# no aparece (main_family.py lo comprueba antes de decorar).
OAUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret