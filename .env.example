# .env.example — Variables de entorno del proyecto AIIP
# Copia este fichero a .env y rellena los valores reales.
# NUNCA commitees el fichero .env — está en .gitignore.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Google AI (Gemini) ────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.1
LLM_MAX_TOKENS=300

# ── Hugging Face ──────────────────────────────────────────────
HF_TOKEN=your-huggingface-read-token
EMBEDDINGS_MODEL=BAAI/bge-m3

# ── Google Drive (Colab) ──────────────────────────────────────
DRIVE_BASE_PATH=/content/drive/MyDrive/TFM Master IA/AIIP

# ── Pipeline RAG ─────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
RAG_TOP_K=5

# ── Ingesta de la KB (E-06) ───────────────────────────────────────────────────
KB_RAW_DATA_PATH=data/raw

# ── Puertos de los entrypoints Chainlit (D-010: nunca hardcodeados) ──────────
PORT_FAMILIAR=8000
PORT_PROFESIONAL=8001
